# App Environment (development/production)
APP_ENV=development

# Database Configuration (Supabase/PostgreSQL)
DATABASE_URL=postgresql://user:password@db-host:5432/postgres?sslmode=require&connect_timeout=10
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Frontend (Duplicate if needed for specific frontend tools)
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Email Receiver (IMAP)
MOCK_MODE=true
IMAP_SERVER=imap.gmail.com
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Email Sender (SMTP)
SMTP_SENDER_EMAIL=your-email@gmail.com
SMTP_SENDER_PASS=your-app-password

# AI Configuration
GEMINI_API_KEY=your-gemini-api-key

# Frontend & API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_TARGET=deps

# Security & Authentication
# JWT_SECRET must match the one used to generate NEXT_PUBLIC_API_TOKEN
JWT_SECRET=inboxradar-jwt-secret-key-super-secure
# The token the frontend uses to authenticate. Generate this based on JWT_SECRET.
NEXT_PUBLIC_API_TOKEN=your-generated-jwt-token

# CORS Settings
ALLOWED_CORS_ORIGINS=https://inboxradar.mutho.tech,http://localhost:3000,http://127.0.0.1:3000
