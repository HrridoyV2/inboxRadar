# App Environment (development/production)
APP_ENV=development

# Database Configuration (Supabase)
# If 5432 times out, 6543 is the alternative. Added connect_timeout to prevent hanging.
DATABASE_URL=postgresql://user:password@db-host:5432/postgres?sslmode=require&connect_timeout=10
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend Configuration
MOCK_MODE=true
IMAP_SERVER=imap.gmail.com
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
SMTP_SENDER_EMAIL=adrijroy99@gmail.com
SMTP_SENDER_PASS=qmmeiemywvpjznhp
GEMINI_API_KEY=your-gemini-api-key

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000/api
FRONTEND_TARGET=deps
